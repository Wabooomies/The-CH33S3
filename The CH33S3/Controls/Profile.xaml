<UserControl x:Class="The_CH33S3.Controls.Profile"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:The_CH33S3.Controls"
             mc:Ignorable="d"
             Background="Transparent"
             d:DesignHeight="100" d:DesignWidth="160">
    <Grid>
        <Border Background="#FF372F58" CornerRadius="35,35,10,10"/>
        <Grid Background="Transparent">
            <Grid.InputBindings>
                <MouseBinding MouseAction="LeftClick" Command="{Binding OpenProfileCommand}" />
            </Grid.InputBindings>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Ellipse x:Name="ProfilePicture"
                     MinWidth="50"
                     MinHeight="50"
                     MaxWidth="200"
                     MaxHeight="200"
                     Margin="15"
                     Cursor="Hand">
                <Ellipse.InputBindings>
                    <MouseBinding MouseAction="LeftClick"
                                  Command="{Binding UploadImageCommand}"/>
                </Ellipse.InputBindings>

                <Ellipse.Fill>
                    <ImageBrush ImageSource="{Binding ProfilePicture}"/>
                </Ellipse.Fill>
            </Ellipse>

            <StackPanel Orientation="Vertical"
                VerticalAlignment="Center"
                Grid.Column="1">
                <TextBlock Foreground="White"
                   FontSize="16"
                   Text="{Binding User.Username}"/>
            </StackPanel>

        </Grid>
    </Grid>
    
</UserControl>
