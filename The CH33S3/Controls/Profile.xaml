<UserControl x:Class="The_CH33S3.Controls.Profile"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:The_CH33S3.Controls"
             mc:Ignorable="d"
             Background="Transparent"
             d:DesignHeight="65" d:DesignWidth="160">
    <Grid Background="#FF372F58">
        <Grid.InputBindings>
            <MouseBinding MouseAction="LeftClick" Command="{Binding OpenProfileCommand}" />
        </Grid.InputBindings>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="65"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Ellipse Grid.Column="0" 
                 Width="45" 
                 Height="45">
            <Ellipse.Fill>
                <ImageBrush ImageSource="{Binding ProfilePicture}"/>
            </Ellipse.Fill>
        </Ellipse>

        <StackPanel Orientation="Vertical"
                    Grid.Column="1">
            <TextBlock VerticalAlignment="Center"
                       HorizontalAlignment="Left"
                       Foreground="White"
                       FontWeight="Bold"
                       FontSize="20"
                       Text="{Binding Username}"/>
        </StackPanel>
        
    </Grid>
</UserControl>
