<UserControl x:Class="The_CH33S3.Controls.ChessGame"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:The_CH33S3.Controls"
             xmlns:conv="clr-namespace:The_CH33S3.Converters"
             mc:Ignorable="d" 
             xmlns:vm="clr-namespace:The_CH33S3.ViewModels">
    <UserControl.DataContext>
        <vm:ChessGameViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <conv:StringToBrushConverter x:Key="StringToBrushConverter"/>
    </UserControl.Resources>

    <Grid >
        <ItemsControl ItemsSource="{Binding Board}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Rows="8" Columns="8" Width="400" Height="400"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Grid Background="{Binding Color, Converter={StaticResource StringToBrushConverter}}">

                        <Border Background="{Binding Piece.Side, Converter={StaticResource StringToBrushConverter}}"
                            Margin="4">
                            <Border.OpacityMask>
                                <ImageBrush ImageSource="{Binding Piece.ImagePath}" Stretch="Uniform"/>
                            </Border.OpacityMask>
                        </Border>
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

    </Grid>
</UserControl>
