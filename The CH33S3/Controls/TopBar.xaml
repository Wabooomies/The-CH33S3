<UserControl x:Class="The_CH33S3.Controls.TopBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:The_CH33S3.Controls"
             xmlns:imgs="clr-namespace:The_CH33S3"
             mc:Ignorable="d" 
             d:DesignHeight="40" d:DesignWidth="800">
    <Grid>
        <Border Background="#FF2F2B44"/>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="40"/>
                <ColumnDefinition Width="75"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="40"/>
                <ColumnDefinition Width="40"/>
                <ColumnDefinition Width="40"/>
            </Grid.ColumnDefinitions>

            <Image Grid.Column="0" 
                   Source="pack://application:,,,/Images/cheese_icon.png" 
                   Margin="7.5"/>
            
            <TextBlock Grid.Column="1" 
                       Text="Chess Game" 
                       VerticalAlignment="Center" 
                       HorizontalAlignment="Center" 
                       Foreground="White" 
                       FontWeight="Bold"/>

            <Button Grid.Column="3"
                    x:Name="MinimizeIcon"
                    Style="{DynamicResource ResourceKey=TopBarIconStyle}" 
                    Content="—"
                    FontWeight="Bold"
                    FontSize="16"
                    WindowChrome.IsHitTestVisibleInChrome="True"
                    Click="Minimize_Click"/>

            <Button Grid.Column="4"
                    x:Name="RestoreIcon"
                    Style="{DynamicResource ResourceKey=TopBarIconStyle}" 
                    Content="⧉"
                    FontWeight="Bold"
                    FontSize="16"
                    WindowChrome.IsHitTestVisibleInChrome="True"
                    Click="Restore_Click"/>

            <Button Grid.Column="5"
                    x:Name="CloseIcon"
                    Style="{DynamicResource ResourceKey=TopBarIconStyle}" 
                    Content="✕"
                    FontWeight="Bold"
                    FontSize="16"
                    WindowChrome.IsHitTestVisibleInChrome="True"
                    Click="Close_Click"/>

        </Grid>
    </Grid>
</UserControl>
