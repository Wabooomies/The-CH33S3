<UserControl
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:The_CH33S3.Views"
             xmlns:Controls="clr-namespace:The_CH33S3.Controls" x:Class="The_CH33S3.Views.Dashboard"
             mc:Ignorable="d" 
             d:DesignHeight="410" d:DesignWidth="800">
    <Grid>
        <Border Background="#FF231E38">
        </Border>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="3.5*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Border Background="#FF120C29" 
                        Margin="15"
                        CornerRadius="50"/>
            </Grid>
            <Grid Grid.Column="0">


                <StackPanel Orientation="Vertical"
                            Margin="35"
                            Grid.Row="1">

                    <Controls:Profile DataContext="{Binding ProfileViewModel}"
                                      Margin="0,0,0,10"/>

                    <Button Style="{DynamicResource StandardButtonStyle}"
                            Content="Play"
                            FontSize="14"
                            FontWeight="Bold"
                            Margin="0,10,0,0"
                            Command="{Binding Play}"/>

                    <Button Style="{DynamicResource StandardButtonStyle}"
                            Content="Log Out"
                            FontSize="14"
                            FontWeight="Bold"
                            Margin="0,10,0,0"
                            Command="{Binding LogOut}"/>

                    <Button Style="{DynamicResource StandardButtonStyle}"
                            Content="Delete Account"
                            FontSize="14"
                            FontWeight="Bold"
                            Margin="0,10,0,0"
                            Command="{Binding DeleteAccount}"/>

                    <Button Style="{DynamicResource StandardButtonStyle}"
                            Content="Exit"
                            FontSize="14"
                            FontWeight="Bold"
                            Margin="0,10,0,0"
                            Command="{Binding Exit}"/>
                </StackPanel>
                
            </Grid>
            <Grid Grid.Column="1" Margin="10">
                <Controls:ChessGame/>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
