<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:vm="clr-namespace:The_CH33S3.ViewModels"
                    xmlns:v="clr-namespace:The_CH33S3.Views"
                    xmlns:c="clr-namespace:The_CH33S3.Controls">
    <DataTemplate DataType="{x:Type vm:LogInViewModel}">
        <v:LogIn />
    </DataTemplate>

    <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
        <v:Dashboard />
    </DataTemplate>

    <DataTemplate DataType="{x:Type vm:ProfileViewModel}">
        <c:Profile />
    </DataTemplate>

    <DataTemplate DataType="{x:Type vm:SignUpViewModel}">
        <v:SignUp />
    </DataTemplate>

    <DataTemplate DataType="{x:Type vm:ChessGameViewModel}">
        <c:ChessGame />
    </DataTemplate>

</ResourceDictionary>