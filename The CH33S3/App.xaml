<Application x:Class="The_CH33S3.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:The_CH33S3"
             xmlns:vm="clr-namespace:The_CH33S3.ViewModels"
             xmlns:v="clr-namespace:The_CH33S3.Views"
             xmlns:c="clr-namespace:The_CH33S3.Controls"
             StartupUri="Views/Container.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <DataTemplate DataType="{x:Type vm:LogInViewModel}">
                <v:LogIn />
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
                <v:Dashboard />
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:ProfileViewModel}">
                <c:Profile />
            </DataTemplate>

            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/TopBarIconResource.xaml"/>
                <ResourceDictionary Source="Themes/StandardButtonResource.xaml"/>
                <ResourceDictionary Source="Themes/StandardTextBoxResource.xaml"/>
                <ResourceDictionary Source="Themes/StandardPasswordBoxResource.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            
        </ResourceDictionary>
    </Application.Resources>
</Application>
